{
  "name": "rlt-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "wasm": "wasm-pack build ../crates/rlt-wasm --target web --out-dir pkg -- --no-default-features",
    "stage": "node scripts/stage-artifacts.mjs",
    "stage:all": "node scripts/stage-artifacts.mjs all",
    "prebuild": "pnpm run wasm && pnpm run stage:all",
    "predev": "pnpm run wasm && pnpm run stage",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/node": "^22.9.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.47",
    "svelte": "^5.1.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "monaco-editor": "^0.52.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
