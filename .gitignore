# Rust build artifacts
/target
**/*.rs.bk
Cargo.lock.orig

# Generated / fetched data — NOT committed (fetched on demand via `cargo xtask fetch-*`)
/resources/lt/
*.rkyv
*.dict
# nlprule engine binaries (fetched via `cargo xtask fetch-engine`)
/resources/*.bin
/resources/*.bin.gz
# Norvig n-gram subsets (fetched via `cargo xtask fetch-ngrams`)
/resources/ngrams/
/resources/*/ngrams/

# wasm-pack output
/crates/rlt-wasm/pkg/

# Node
node_modules/

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/

# insta pending snapshots
*.snap.new

# L4 neural model artifacts (gector-derived; large + non-commercial) — per-language under resources/<lang>/
/resources/*/l4/

# Adaptability sweep working data (the committed report is docs/adaptability.md)
/resources/adaptability/

# LanguageTool segmentation rules (fetched, LGPL data)
/resources/segment.srx

# AGID inflection + part-of-speech databases (fetched; the native POS tagger's source — build-tagger)
/resources/agid-infl.txt
/resources/agid-pos.txt

# Claude Code local state
/.claude/

# LanguageTool morfologik POS dictionaries (fetched per-language from *-pos-dict jars, LGPL).
# *.dict is globbed above; the .info / jar are not:
/resources/*/pos.info
/resources/*/pos-dict.jar
